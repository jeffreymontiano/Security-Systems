# Copy this file to .env and fill in real values before deploying.

# Random long secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Port the server listens on (most hosts like Render/Railway set this for you)
PORT=3000

# Your Neon Postgres connection string (from the Neon dashboard -> Connection Details)
DATABASE_URL=postgresql://user:password@your-project.neon.tech/neondb?sslmode=require

# Credentials used ONLY the very first time the server starts, to create
# the initial Admin account (if no users exist yet in the database).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-password
INITIAL_ADMIN_NAME=System Administrator
